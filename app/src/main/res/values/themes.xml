<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Pavan_digi_wallet" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Pavan_digi_wallet" parent="Base.Theme.Pavan_digi_wallet" />

    <style name="KeypadButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_margin">1dp</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1A1C1E</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KeypadButtonBlue" parent="KeypadButton">
        <item name="android:background">#00796B</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="KeypadButtonGreen" parent="KeypadButtonBlue">
        <item name="android:background">#006064</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="KeypadSuggestion">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1A1C1E</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>